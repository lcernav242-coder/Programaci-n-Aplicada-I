<Window x:Class="RadioCheck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RadioCheck"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="100" Margin="27,49,0,0" Stroke="Black" VerticalAlignment="Top" Width="341"/>
        <CheckBox Content="Camabiar tipo der letra" x:Name="cbTipoLetra" HorizontalAlignment="Left" Margin="40,59,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Camabiar color de texto" x:Name="cbColorTexto" HorizontalAlignment="Left" Margin="40,84,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Camabiar color de fondo" x:Name="cbColorFondo" HorizontalAlignment="Left" Margin="40,109,0,0" VerticalAlignment="Top"/>
        <Button Content="Aplicar" x:Name="btnAplicarCheckBox" HorizontalAlignment="Left" Margin="261,61,0,0" VerticalAlignment="Top" Click="btnAplicarCheckBox_Click"/>
        <Label Content="Uso de control CheckBox" x:Name="lbCheckBox" HorizontalAlignment="Left" Margin="216,84,0,0" VerticalAlignment="Top"/>
        <Label Content="Control de checkBox" HorizontalAlignment="Left" Margin="27,18,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>